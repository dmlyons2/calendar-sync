# Outlook published .ics feed (treat as a secret — it's an unauthenticated read URL)
ICS_URL=https://outlook.office365.com/owa/calendar/.../calendar.ics

# Dedicated Google Calendar ID — never the primary calendar
TARGET_CALENDAR_ID=abc123@group.calendar.google.com

# Path to Google service account JSON key
GOOGLE_APPLICATION_CREDENTIALS=/etc/calendar-sync/service-account.json

# Optional
SYNC_LOOKBACK_DAYS=30
SYNC_LOOKAHEAD_DAYS=365
DEFAULT_TZ=America/Los_Angeles
LOG_LEVEL=INFO
